{
  "_comment": "OpenClaw Command Center — Agent Configuration Template",
  "_instructions": "Copy this to ~/.openclaw/openclaw.json and fill in your API keys via 'openclaw configure'",

  "auth": {
    "profiles": {
      "moonshot:default": {
        "provider": "moonshot",
        "mode": "api_key"
      },
      "openrouter:default": {
        "provider": "openrouter",
        "mode": "api_key"
      }
    }
  },

  "models": {
    "mode": "merge",
    "providers": {
      "moonshot": {
        "baseUrl": "https://api.moonshot.ai/v1",
        "api": "openai-completions",
        "models": [
          {
            "id": "kimi-k2.5",
            "name": "Kimi K2.5",
            "reasoning": false,
            "input": ["text", "image"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 256000,
            "maxTokens": 8192
          }
        ]
      },
      "openrouter": {
        "baseUrl": "https://openrouter.ai/api/v1",
        "api": "openai-completions",
        "models": [
          {
            "id": "minimax/minimax-m2.5",
            "name": "MiniMax M2.5",
            "reasoning": false,
            "input": ["text", "image"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 1000000,
            "maxTokens": 8192
          }
        ]
      }
    }
  },

  "agents": {
    "defaults": {
      "model": {
        "primary": "moonshot/kimi-k2.5"
      },
      "heartbeat": {
        "every": "60m",
        "model": "openrouter/google/gemini-2.5-flash-lite",
        "target": "last"
      }
    },
    "list": [
      {
        "id": "main",
        "_comment": "Jansky — Boss/orchestrator, TTS voice: onyx, thinking: low"
      },
      {
        "id": "claw-1",
        "name": "Orbit",
        "workspace": "<project-path>/agents/claw-1",
        "model": "moonshot/kimi-k2.5",
        "_comment": "Coding/tasks agent, TTS voice: echo, thinking: off"
      },
      {
        "id": "claw-2",
        "name": "Nova",
        "workspace": "<project-path>/agents/claw-2",
        "model": "moonshot/kimi-k2.5",
        "_comment": "Research/web agent, TTS voice: fable, thinking: off"
      }
    ]
  },

  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "session-memory": {
          "enabled": true,
          "flushBeforeCompaction": true,
          "softThreshold": 4000
        }
      }
    }
  },

  "session": {
    "dmScope": "per-peer"
  },

  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "<generate-a-token-or-use-openclaw-configure>"
    }
  }
}
